<script>
const maliciousDomains = [
  "grabify.link",
  "grabify.org",
  "urlto.me",
  "urlty.co",
  "grem.io",
  "gyo.tc",
  "hd.gd",
  "onbit.pro",
  "snifferip.com",
  "unl.one",
  "leancoding.co",
  "stopify.co",
  "yo9.io",
  "g9x.de",
  "starrynight.link",
  "fortnight.space",
  "yip.su",
  "iplogger.org",
  "2no.co",
  "iplogger.com",
  "iplogger.ru",
  "yp9.ru",
  "blasze.com",
  "blasze.tk",
  "cliip.net",
  "ps3cfw.com",
  "ezstat.ru",
  "logger.online",
  "quickip.ru",
  "shorte.st"
];

function checkLink() {
  const input = document.getElementById("urlInput").value.trim();
  const resultDiv = document.getElementById("result");
  
  if (!input) {
    resultDiv.style.display = "block";
    resultDiv.className = "danger";
    resultDiv.innerHTML = "Please enter a URL to check.";
    return;
  }

  let processedUrl = input;
  if (!/^https?:\/\//i.test(processedUrl)) {
    processedUrl = 'http://' + processedUrl;
  }

  try {
    const urlObj = new URL(processedUrl);
    const hostname = urlObj.hostname.toLowerCase();
    
    // Check if domain is in our list
    let isLogger = maliciousDomains.some(domain => hostname === domain || hostname.endsWith('.' + domain));
    
    resultDiv.style.display = "block";
    
    if (isLogger) {
      // Determine if it's JUST the main domain website or root path (e.g., grabify.org/ or grabify.org)
      const isJustDomain = urlObj.pathname === "/" || urlObj.pathname === "";
      
      if (isJustDomain) {
        resultDiv.className = "creator-warning";
        resultDiv.innerHTML = `This is an IP logger creator!`;
      } else {
        resultDiv.className = "danger";
        resultDiv.innerHTML = `<strong>This link is an IP logger!</strong>`;
      }
    } else {
      resultDiv.className = "safe";
      resultDiv.innerHTML = `This link is safe!`;
    }
  } catch (e) {
    resultDiv.style.display = "block";
    resultDiv.className = "danger";
    resultDiv.innerHTML = "Invalid URL structure. Please check the text and try again.";
  }
}
</script>

